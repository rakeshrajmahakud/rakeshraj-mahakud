{% liquid
  assign desktop_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image

  if mobile_image == blank
    assign mobile_image = desktop_image
  endif
%}

{% style %}
  .gift-banner__content.background-box{
    background: 
  }
{% endstyle %}

<div class="gift-banner banner__overlay--{{ section.settings.content_position }}">
  <div class="gift-banner__content {% if section.settings.active_container %} background-box {% endif %}">
    <div class="gift-banner__content-inner">
      {% if section.settings.heading != blank %}
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="rte">
          {{ section.settings.text }}
        </div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="rm-btn rm-btn--primary"
        >
          <span>{{ section.settings.button_label }}</span>
          {% render 'icon-arrow-right' %}
        </a>
      {% endif %}
    </div>
  </div>
  <picture>
    {% if mobile_image %}
      <source
        media="(max-width: 749px)"
        srcset="
          {{ mobile_image | image_url: width: 375 }} 375w,
          {{ mobile_image | image_url: width: 550 }} 550w,
          {{ mobile_image | image_url: width: 750 }} 750w
        "
      >
    {% endif %}

    {% if desktop_image %}
      {{
        desktop_image
        | image_url: width: 2000
        | image_tag: loading: 'lazy', widths: '750,1100,1500,1800,2000', sizes: '100vw', class: 'gift-banner__image'
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag }}
    {% endif %}
  </picture>
</div>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "default": "middle-center",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "middle-left", "label": "Middle Left" },
        { "value": "middle-center", "label": "Middle Center" },
        { "value": "middle-right", "label": "Middle Right" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "bottom-right", "label": "Bottom Right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}

<style>
  /* allignment */
  .banner__overlay--top-left {
    justify-content: flex-start;
    align-items: flex-start;
  }
  .banner__overlay--top-center {
    justify-content: center;
    align-items: flex-start;
  }
  .banner__overlay--top-right {
    justify-content: flex-end;
    align-items: flex-start;
  }
  .banner__overlay--middle-left {
    justify-content: flex-start;
    align-items: center;
  }
  .banner__overlay--middle-center {
    justify-content: center;
    align-items: center;
  }
  .banner__overlay--middle-right {
    justify-content: flex-end;
    align-items: center;
  }
  .banner__overlay--bottom-left {
    justify-content: flex-start;
    align-items: flex-end;
  }
  .banner__overlay--bottom-center {
    justify-content: center;
    align-items: flex-end;
  }
  .banner__overlay--bottom-right {
    justify-content: flex-end;
    align-items: flex-end;
  }

  .gift-banner {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .gift-banner picture,
  .gift-banner img {
    display: block;
    width: 100%;
  }
  .gift-banner img {
    height: auto;
  }
  .gift-banner__content {
    gap: 5rem;
    margin: 5rem;
    position: absolute;
    z-index: 1;
  }
  .gift-banner__content-inner {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    line-height: normal;
    max-width: 560px;
  }
  @media screen and (max-width: 749px) {
    .gift-banner__content-inner {
      text-align: center;
    }
  }
  @media screen and (min-width: 750px) {
    .gift-banner {
      flex-direction: row;
    }
    .gift-banner__content-inner {
      display: flex;
      gap: 5rem;
    }
  }
</style>
